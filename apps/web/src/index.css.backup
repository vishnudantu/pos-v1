@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700&display=swap');

@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --nethra-teal: #00d4aa;
  --nethra-blue: #1e88e5;
  --nethra-amber: #ff9800;
  --nethra-red: #ff5555;
  --nethra-bg: #0b1221;
  --nethra-bg-elevated: #0d1628;
  --nethra-card: rgba(255, 255, 255, 0.04);
  --nethra-card-hover: rgba(255, 255, 255, 0.07);
  --nethra-border: rgba(255, 255, 255, 0.08);
  --nethra-border-strong: rgba(255, 255, 255, 0.14);
  --nethra-text: #f0f4ff;
  --nethra-text-secondary: #8899bb;
  --nethra-text-tertiary: rgba(136, 153, 187, 0.6);
  --nethra-radius: 16px;
  --nethra-radius-sm: 10px;
  --nethra-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
  --nethra-glow-teal: 0 0 30px rgba(0, 212, 170, 0.25);
}

* { box-sizing: border-box; }

html {
  font-family: 'Inter', system-ui, sans-serif;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  margin: 0;
  padding: 0;
  min-height: 100vh;
  background: var(--nethra-bg);
  background-image:
    radial-gradient(circle at 15% 0%, rgba(0, 212, 170, 0.08) 0%, transparent 35%),
    radial-gradient(circle at 85% 100%, rgba(30, 136, 229, 0.08) 0%, transparent 35%);
  color: var(--nethra-text);
  overflow-x: hidden;
}

::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(136, 153, 187, 0.25); border-radius: 10px; }
::-webkit-scrollbar-thumb:hover { background: rgba(136, 153, 187, 0.45); }

h1, h2, h3, h4, h5, h6 {
  font-family: 'Space Grotesk', system-ui, sans-serif;
  margin: 0;
}

select, input, textarea { color-scheme: dark; }
select option { background-color: #151b2e; color: #e2e8f0; }

@keyframes spin { to { transform: rotate(360deg); } }
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.animate-spin { animation: spin 1s linear infinite; }
.animate-shimmer {
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
  background-size: 200% 100%;
  animation: shimmer 2s infinite;
}
.animate-float { animation: float 6s ease-in-out infinite; }

@layer components {
  .nethra-glass {
    background: var(--nethra-card);
    backdrop-filter: blur(16px);
    border: 1px solid var(--nethra-border);
    border-radius: var(--nethra-radius);
  }
  .nethra-glass-hover { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
  .nethra-glass-hover:hover {
    background: var(--nethra-card-hover);
    border-color: var(--nethra-border-strong);
    transform: translateY(-2px);
  }
  .nethra-gradient-text {
    background: linear-gradient(135deg, var(--nethra-teal), var(--nethra-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .nethra-focus-ring:focus-visible {
    outline: none;
    box-shadow: 0 0 0 2px rgba(0, 212, 170, 0.35);
  }
  .touch-min { min-height: 48px; min-width: 48px; }
}

.floating-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.35;
  pointer-events: none;
}
.floating-orb.teal { background: radial-gradient(circle, var(--nethra-teal), transparent 70%); }
.floating-orb.blue { background: radial-gradient(circle, var(--nethra-blue), transparent 70%); }
.floating-orb.amber { background: radial-gradient(circle, var(--nethra-amber), transparent 70%); }

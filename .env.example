# ─────────────────────────────────────────────────────────────
# NETHRA - Environment Variables Template
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── Supabase (Frontend)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (Server - service role key, never expose to browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Express Server
PORT=3001
FRONTEND_URL=http://localhost:5173
# Production: FRONTEND_URL=https://yourdomain.com

# ── SMS Gateway
# Get key from https://www.fast2sms.com
FAST2SMS_API_KEY=your-fast2sms-key-here

# ── AI Provider (choose one)
# openai | anthropic | ollama
AI_PROVIDER=openai

# OpenAI / OpenAI-compatible
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
# ANTHROPIC_API_KEY=your-anthropic-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1
